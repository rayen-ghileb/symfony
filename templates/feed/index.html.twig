{# templates/feed/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Feed — Safe Space{% endblock %}

{% block stylesheets %}
<style>
/* ══════════════════════════════════════════════
   SafeSpace Feed — Twig port of JavaFX design
   Indigo/violet theme · Segoe UI · Bootstrap 5.3
══════════════════════════════════════════════ */

/* ── Feed layout ──────────────────────────── */
.ss-feed-wrap {
    display: flex;
    justify-content: center;
    padding: 28px 80px;
    min-height: calc(100vh - 62px);
}
.ss-feed-inner {
    width: 100%;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* ── Welcome Banner ───────────────────────── */
.ss-welcome {
    background: linear-gradient(to right, var(--indigo), var(--violet));
    border-radius: var(--radius-card);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 16px rgba(79,70,229,.3);
}
.ss-welcome-title { font-size: 18px; font-weight: 700; color: #fff; }
.ss-welcome-sub   { font-size: 13px; color: rgba(255,255,255,.75); }
.ss-welcome-icon-wrap {
    margin-left: auto;
    width: 52px; height: 52px;
    background: rgba(255,255,255,.15);
    border: 1.5px solid rgba(255,255,255,.25);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 26px;
    flex-shrink: 0;
}

/* ── Create Post Card ─────────────────────── */
.ss-card {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 20px;
}
.ss-card:hover { box-shadow: var(--shadow-card-hover); }

.ss-create-avatar {
    width: 42px; height: 42px;
    background: var(--indigo-light);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--indigo);
    font-size: 15px;
    flex-shrink: 0;
}
.ss-textarea {
    background: var(--gray-50);
    border: 1.5px solid var(--gray-200);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--gray-900);
    resize: none;
    width: 100%;
    transition: border-color .2s, background .2s;
    outline: none;
    font-family: inherit;
}
.ss-textarea::placeholder { color: var(--gray-400); }
.ss-textarea:focus { border-color: var(--indigo); border-width: 2px; background: #fff; }

/* Visibility toggles */
.ss-vis-label { font-size: 12px; font-weight: 600; color: var(--gray-400); }
.ss-vis-btn {
    background: var(--gray-100);
    border: 1.5px solid transparent;
    border-radius: var(--radius-xs);
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-500);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: all .2s;
}
.ss-vis-btn:hover  { background: var(--indigo-light); color: var(--indigo); }
.ss-vis-btn.active { background: var(--indigo-light); border-color: var(--indigo); color: var(--indigo); }

/* Media upload grid */
.ss-up-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    min-height: 40px;
    align-items: flex-start;
}
.ss-up-empty {
    font-size: 13px;
    color: var(--gray-400);
    font-style: italic;
    align-self: center;
    padding: 4px 0;
}
.ss-up-thumb {
    position: relative;
    width: 80px; height: 80px;
    border-radius: var(--radius-xs);
    overflow: hidden;
    border: 1.5px solid var(--indigo-mid);
    background: var(--indigo-light);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.ss-up-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.ss-up-vid-icon { font-size: 22px; line-height: 1; }
.ss-up-remove {
    position: absolute; top: 4px; right: 4px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.50);
    border: none; cursor: pointer;
    color: #fff; font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    padding: 0; line-height: 1;
    transition: background 0.15s;
}
.ss-up-remove:hover { background: rgba(220,38,38,0.85); }
.ss-up-add-btn {
    width: 80px; height: 80px;
    border-radius: var(--radius-xs);
    border: 1.5px dashed var(--indigo-mid);
    background: var(--indigo-light);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 3px; cursor: pointer;
    color: var(--indigo); font-size: 22px;
    transition: border-color 0.15s, background 0.15s;
    flex-shrink: 0;
    user-select: none;
    font-weight: 700;
}
.ss-up-add-btn span.ss-up-add-label { font-size: 11px; font-weight: 600; }
.ss-up-add-btn:hover { border-color: var(--indigo); background: #ddd6fe; }

.ss-post-btn {
    background: linear-gradient(to right, var(--indigo), var(--violet));
    border: none;
    border-radius: var(--radius-sm);
    padding: 9px 24px;
    font-size: 13.5px;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    box-shadow: var(--shadow-btn);
    transition: transform .15s, box-shadow .15s;
}
.ss-post-btn:hover  { transform: scale(1.02); box-shadow: 0 5px 16px rgba(79,70,229,.6); }
.ss-post-btn:active { transform: scale(0.98); }

/* ── Filter Bar ───────────────────────────── */
.ss-filters {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    padding: 10px 16px;
    box-shadow: 0 1px 6px rgba(0,0,0,.04);
}
.ss-filter-label { font-size: 12.5px; font-weight: 600; color: var(--gray-400); margin-right: 2px; }
.ss-filter-btn {
    background: var(--gray-100);
    border: none;
    border-radius: var(--radius-xs);
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-500);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: all .2s;
    text-decoration: none;
}
.ss-filter-btn:hover  { background: var(--indigo-light); color: var(--indigo); }
.ss-filter-btn.active {
    background: var(--indigo);
    color: #fff;
    box-shadow: 0 2px 8px rgba(79,70,229,.3);
}
.ss-filter-btn.active .bi { color: #fff; }
.ss-latest-tag {
    margin-left: auto;
    background: var(--gray-100);
    border-radius: var(--radius-xs);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--gray-400);
}

/* ── Post Card ────────────────────────────── */
.ss-post-card {
    background: #fff;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 20px;
    transition: box-shadow .2s, border-color .2s;
}
.ss-post-card:hover {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--gray-200);
}

/* Post header */
.ss-post-header { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.ss-post-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: #fff;
    flex-shrink: 0;
}
.ss-author-name  { font-weight: 700; font-size: 15px; color: var(--gray-800); }
.ss-post-time    { font-size: 13px; color: var(--gray-400); margin-left: 8px; }
.ss-author-role  { font-size: 12px; font-weight: 600; margin-top: 1px; }
.ss-author-role-patient      { color: var(--indigo); }
.ss-author-role-psychiatrist { color: var(--green); }
.ss-author-role-admin        { color: var(--amber); }

.ss-post-menu-btn {
    margin-left: auto;
    background: transparent;
    border: none;
    font-size: 20px;
    color: var(--gray-400);
    cursor: pointer;
    padding: 0 8px;
    line-height: 1;
    border-radius: 6px;
    transition: background .15s;
}
.ss-post-menu-btn:hover { background: var(--gray-100); color: var(--gray-700); }

/* Post content */
.ss-post-content {
    font-size: 14px;
    color: #1f2937;
    line-height: 1.65;
    margin-bottom: 14px;
    white-space: pre-wrap;
}

/* ── Facebook-style media grid ───────────────── */
.ss-media-grid {
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 14px;
    display: grid;
    gap: 2px;
}
.ss-media-grid.count-1 { grid-template-columns: 1fr; }
.ss-media-grid.count-1 .ss-media-cell { height: 340px; }
.ss-media-grid.count-2 { grid-template-columns: 1fr 1fr; }
.ss-media-grid.count-2 .ss-media-cell { height: 250px; }
.ss-media-grid.count-3 { grid-template-columns: 2fr 1fr; grid-template-rows: 130px 130px; }
.ss-media-grid.count-3 .ss-media-cell:first-child { grid-row: 1 / 3; height: 262px; }
.ss-media-grid.count-3 .ss-media-cell:not(:first-child) { height: 130px; }
.ss-media-grid.count-4 { grid-template-columns: 1fr 1fr; grid-template-rows: 175px 175px; }
.ss-media-grid.count-4 .ss-media-cell { height: 175px; }
.ss-media-grid.count-5plus { grid-template-columns: 1fr 1fr; grid-template-rows: 180px 175px; }
.ss-media-grid.count-5plus .ss-media-cell:first-child { grid-column: 1 / 3; height: 180px; }
.ss-media-grid.count-5plus .ss-media-cell:not(:first-child) { height: 175px; }
.ss-media-cell {
    position: relative;
    overflow: hidden;
    background: var(--gray-200);
    display: block;
}
.ss-media-cell img,
.ss-media-cell video {
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
    background: #ffffff;
}
.ss-media-more-overlay {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; font-weight: 700; color: #fff;
    cursor: pointer;
    letter-spacing: -1px;
}

/* ── Reactions Preview Row ─────────────────── */
.ss-reactions-preview {
    display: flex;
    align-items: center;
    padding: 4px 0 10px;
    border-bottom: 1px solid var(--gray-100);
    margin-bottom: 10px;
}
.ss-reaction-icons { display: flex; align-items: center; gap: 2px; }
.ss-reaction-icon-wrap {
    width: 24px; height: 24px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 1px 4px rgba(0,0,0,.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    margin-left: -4px;
}
.ss-reaction-icon-wrap:first-child { margin-left: 0; }
.ss-reaction-count { font-size: 12.5px; color: var(--gray-500); margin-left: 6px; }
.ss-no-reactions   { font-size: 12.5px; color: var(--gray-400); font-style: italic; }
.ss-comment-toggle-btn {
    margin-left: auto;
    background: none; border: none;
    font-size: 12.5px; color: var(--gray-400);
    cursor: pointer; padding: 0;
    transition: color .15s;
}
.ss-comment-toggle-btn:hover { color: var(--indigo); }

/* ── Reaction Buttons Bar ─────────────────── */
.ss-reaction-bar {
    display: flex;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 0;
}
.ss-reaction-bar form { flex: 1; margin: 0; }
.ss-rxn-btn {
    width: 100%;
    background: transparent;
    border: none;
    border-left: 1px solid var(--gray-200);
    padding: 10px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-500);
    cursor: pointer;
    transition: background .2s, color .2s;
}
.ss-reaction-bar form:first-child .ss-rxn-btn { border-left: none; }
.ss-rxn-btn:hover  { background: var(--gray-100); }
.ss-rxn-btn.active { background: var(--indigo-light); color: var(--indigo); }
.ss-rxn-btn .rxn-count {
    font-size: 12px;
    background: var(--gray-200);
    border-radius: 20px;
    padding: 1px 7px;
    font-weight: 700;
    color: var(--gray-600);
}
.ss-rxn-btn.active .rxn-count { background: #c4b5fd; color: var(--indigo); }

/* ── Comments Section ─────────────────────── */
.ss-comments-section {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--gray-100);
}
.ss-comments-header { display: flex; align-items: center; margin-bottom: 12px; }
.ss-comments-title { font-weight: 700; font-size: 14px; color: var(--gray-800); }
.ss-hide-btn {
    margin-left: auto;
    background: none; border: none;
    font-size: 12px; color: var(--indigo); cursor: pointer;
}

/* Individual comment */
.ss-comment { display: flex; gap: 10px; padding: 8px 0; }
.ss-comment-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 11px; color: #fff;
    flex-shrink: 0;
    border: 2px solid #fff;
}
.ss-comment-body { flex: 1; min-width: 0; }
.ss-comment-author  { font-weight: 700; font-size: 13px; color: var(--gray-800); }
.ss-comment-time    { font-size: 11px; color: var(--gray-400); margin-left: 8px; }
.ss-comment-edited  { font-size: 10px; color: var(--gray-400); font-style: italic; margin-left: 4px; }
.ss-comment-text    { font-size: 13px; color: var(--gray-700); margin: 3px 0; line-height: 1.5; }
.ss-comment-actions { display: flex; gap: 12px; margin-top: 4px; }
.ss-comment-action-btn {
    background: none; border: none;
    font-size: 11px; font-weight: 600;
    cursor: pointer; padding: 2px 0;
    transition: color .15s;
}
.ss-reply-btn  { color: var(--indigo); }
.ss-edit-btn   { color: var(--gray-500); }
.ss-delete-btn { color: var(--red); }
.ss-reply-btn:hover  { color: var(--violet); text-decoration: underline; }
.ss-edit-btn:hover   { color: var(--gray-800); text-decoration: underline; }
.ss-delete-btn:hover { color: #dc2626; text-decoration: underline; }

/* Reply block */
.ss-replies-block {
    margin-left: 42px;
    margin-top: 8px;
    background: #f0f0ff;
    border: 1px solid #d0d0ff;
    border-radius: var(--radius-xs);
    padding: 8px;
}
.ss-reply-indicator {
    font-size: 11px; color: var(--gray-400);
    margin-bottom: 2px;
    padding-left: 42px;
}

/* Comment / Reply input */
.ss-comment-input-wrap { display: flex; gap: 8px; margin-top: 14px; }
.ss-comment-input {
    flex: 1;
    background: var(--gray-50);
    border: 1.5px solid var(--gray-200);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 13px;
    color: var(--gray-800);
    outline: none;
    font-family: inherit;
    transition: border-color .2s;
}
.ss-comment-input::placeholder { color: var(--gray-400); }
.ss-comment-input:focus { border-color: var(--indigo); background: #fff; }
.ss-comment-submit-btn {
    background: var(--indigo);
    border: none;
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    cursor: pointer;
    transition: background .2s;
    flex-shrink: 0;
}
.ss-comment-submit-btn:hover { background: var(--violet); }

/* Inline edit form */
.ss-inline-edit { display: none; margin-top: 6px; }
.ss-inline-edit.show { display: flex; gap: 8px; }
.ss-inline-edit textarea {
    flex: 1;
    border: 1.5px solid var(--indigo);
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 13px;
    font-family: inherit;
    outline: none;
    resize: none;
    background: var(--indigo-light);
}
.ss-inline-edit-save {
    background: var(--indigo);
    border: none; border-radius: 10px;
    padding: 8px 14px;
    color: #fff; font-size: 13px; font-weight: 600;
    cursor: pointer;
}
.ss-inline-edit-cancel {
    background: var(--gray-100);
    border: none; border-radius: 10px;
    padding: 8px 14px;
    color: var(--gray-700); font-size: 13px;
    cursor: pointer;
}

/* Reply toggle btn */
.ss-replies-toggle {
    background: none; border: none;
    color: var(--indigo); font-size: 12px; cursor: pointer;
    padding: 4px 0 4px 42px;
    display: block;
    transition: color .15s;
}
.ss-replies-toggle:hover { color: var(--violet); text-decoration: underline; }

/* ── No Posts Empty State ─────────────────── */
.ss-empty-state {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-card);
    padding: 48px;
    text-align: center;
}
.ss-empty-icon-wrap {
    width: 72px; height: 72px;
    background: var(--gray-100);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px;
    font-size: 30px; color: var(--gray-400);
}
.ss-empty-title { font-size: 18px; font-weight: 700; color: var(--gray-800); margin-bottom: 6px; }
.ss-empty-sub   { font-size: 13.5px; color: var(--gray-500); }

/* ── Visibility badge on posts ────────────── */
.ss-vis-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    background: var(--gray-100);
    color: var(--gray-500);
}
.ss-vis-badge-public         { background: #dcfce7; color: #16a34a; }
.ss-vis-badge-patients_only  { background: var(--indigo-light); color: var(--indigo); }

/* ── No comments placeholder ──────────────── */
.ss-no-comments {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
}
.ss-no-comments p { margin: 0; font-size: 13px; color: var(--gray-500); }
.ss-no-comments small { font-size: 12px; color: var(--gray-400); font-style: italic; }

/* ── Flash toasts ─────────────────────────── */
.ss-toast-success {
    background: #f0fdf4;
    border: 1.5px solid #bbf7d0;
    border-radius: 12px;
    padding: 14px 18px;
    display: flex; align-items: center; gap: 10px;
    color: #166534;
    font-size: 13.5px;
    box-shadow: 0 4px 16px rgba(22,163,74,.15);
}
.ss-toast-error {
    background: #fef2f2;
    border: 1.5px solid #fecaca;
    border-radius: 12px;
    padding: 14px 18px;
    display: flex; align-items: center; gap: 10px;
    color: #991b1b;
    font-size: 13.5px;
    box-shadow: 0 4px 16px rgba(220,38,38,.15);
}

/* ── AJAX toast notification ──────────────── */
#ajax-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    min-width: 260px;
    max-width: 400px;
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    box-shadow: 0 8px 30px rgba(0,0,0,.15);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity .25s, transform .25s;
    pointer-events: none;
}
#ajax-toast.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}
#ajax-toast.toast-success { background: #f0fdf4; border: 1.5px solid #bbf7d0; color: #166534; }
#ajax-toast.toast-danger  { background: #fef2f2; border: 1.5px solid #fecaca; color: #991b1b; }

/* ── Delete confirm modal ─────────────────── */
.ss-confirm-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.35);
    z-index: 500;
    align-items: center; justify-content: center;
}
.ss-confirm-overlay.show { display: flex; }
.ss-confirm-box {
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    width: 360px;
    box-shadow: 0 8px 30px rgba(0,0,0,.15);
    text-align: center;
}
.ss-confirm-title { font-size: 17px; font-weight: 700; color: var(--gray-900); margin-bottom: 8px; }
.ss-confirm-sub   { font-size: 13px; color: var(--gray-500); margin-bottom: 20px; }
.ss-confirm-btns  { display: flex; gap: 10px; justify-content: center; }
.ss-confirm-cancel {
    background: var(--gray-100); border: none;
    border-radius: 10px; padding: 9px 22px;
    font-size: 13.5px; color: var(--gray-700); cursor: pointer;
}
.ss-confirm-delete {
    background: #dc2626; border: none;
    border-radius: 10px; padding: 9px 22px;
    font-size: 13.5px; font-weight: 600; color: #fff; cursor: pointer;
}

/* ── Responsive ───────────────────────────── */
@media (max-width: 768px) {
    .ss-feed-wrap { padding: 16px 12px; }
}

/* hide separator after last comment */
.ss-comment-sep:last-of-type { display: none; }

/* ── Edit Post Modal ──────────────────────── */
.ss-modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 600;
    align-items: center;
    justify-content: center;
    padding: 20px;
}
.ss-modal-overlay.show { display: flex; }
.ss-modal {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,.2);
    overflow: hidden;
}
.ss-modal-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 24px 24px 0;
    flex-shrink: 0;
}
.ss-modal-icon-wrap {
    width: 42px; height: 42px;
    background: var(--indigo-light);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--indigo);
    font-size: 16px;
    flex-shrink: 0;
}
.ss-modal-title    { font-size: 17px; font-weight: 700; color: var(--gray-900); }
.ss-modal-subtitle { font-size: 12.5px; color: var(--gray-400); margin-top: 1px; }
.ss-modal-close {
    margin-left: auto;
    width: 32px; height: 32px;
    background: var(--gray-100);
    border: none; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: var(--gray-500);
    cursor: pointer; flex-shrink: 0;
    transition: background .15s, color .15s;
}
.ss-modal-close:hover { background: var(--red-bg); color: var(--red); }
.ss-modal-divider {
    height: 1px;
    background: var(--gray-100);
    margin: 20px 0 0;
    flex-shrink: 0;
}
.ss-modal-body {
    overflow-y: auto;
    padding: 20px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
}
.ss-modal-section-label {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--gray-700);
    margin-bottom: 8px;
    display: block;
}
.ss-modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    flex-shrink: 0;
}
.ss-modal-cancel {
    background: var(--gray-100);
    border: none; border-radius: 10px;
    padding: 9px 22px;
    font-size: 13.5px; color: var(--gray-700);
    cursor: pointer; font-family: inherit;
    transition: background .15s;
}
.ss-modal-cancel:hover { background: var(--gray-200); }
.ss-modal-save {
    background: linear-gradient(to right, var(--indigo), var(--violet));
    border: none; border-radius: 10px;
    padding: 9px 22px;
    font-size: 13.5px; font-weight: 700; color: #fff;
    cursor: pointer; font-family: inherit;
    box-shadow: var(--shadow-btn);
    transition: transform .15s, box-shadow .15s;
}
.ss-modal-save:hover  { transform: scale(1.02); box-shadow: 0 5px 16px rgba(79,70,229,.5); }
.ss-modal-save:active { transform: scale(0.98); }

/* Current media thumbs inside modal */
.ss-modal-media-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.ss-modal-media-item {
    position: relative;
    width: 80px; height: 80px;
    border-radius: var(--radius-xs);
    overflow: hidden;
    border: 1.5px solid var(--gray-200);
    background: var(--gray-100);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.ss-modal-media-item img,
.ss-modal-media-item video { width: 100%; height: 100%; object-fit: cover; display: block; }
.ss-modal-media-del {
    position: absolute; top: 4px; right: 4px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    border: none; cursor: pointer;
    color: #fff; font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    padding: 0; transition: background .15s;
}
.ss-modal-media-del:hover { background: rgba(220,38,38,.85); }
.ss-modal-no-media { font-size: 13px; color: var(--gray-400); font-style: italic; padding: 4px 0; }
.ss-modal-add-media-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--gray-100);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-sm);
    padding: 8px 16px;
    font-size: 13px; font-weight: 600; color: var(--gray-700);
    cursor: pointer; font-family: inherit;
    transition: all .2s;
    margin-top: 4px;
}
.ss-modal-add-media-btn:hover {
    background: var(--indigo-light);
    border-color: var(--indigo-mid);
    color: var(--indigo);
}
</style>
{% endblock %}

{% block body %}
{# ── helpers ── #}
{% macro avatarClass(role) %}{% if role == 'PSYCHIATRIST' %}ss-avatar-psychiatrist{% elseif role == 'ADMIN' %}ss-avatar-admin{% else %}ss-avatar-patient{% endif %}{% endmacro %}
{% macro roleClass(role)   %}{% if role == 'PSYCHIATRIST' %}ss-author-role-psychiatrist{% elseif role == 'ADMIN' %}ss-author-role-admin{% else %}ss-author-role-patient{% endif %}{% endmacro %}
{% macro avatarBg(role)    %}{% if role == 'PSYCHIATRIST' %}background:#10b981{% elseif role == 'ADMIN' %}background:#f59e0b{% else %}background:#4f46e5{% endif %}{% endmacro %}
{% macro initials(name)    %}{% set parts = name|split(' ') %}{{ parts[0]|slice(0,1)|upper }}{% if parts[1] is defined %}{{ parts[1]|slice(0,1)|upper }}{% endif %}{% endmacro %}
{% macro timeAgo(dt) %}
    {% if dt %}
        {% set diff = "now"|date('U') - dt|date('U') %}
        {% if diff < 60 %}Just now
        {% elseif diff < 3600 %}{{ (diff / 60)|round }} min ago
        {% elseif diff < 86400 %}{{ (diff / 3600)|round }}h ago
        {% elseif diff < 604800 %}{{ (diff / 86400)|round }}d ago
        {% else %}{{ dt|date('M d, Y') }}
        {% endif %}
    {% endif %}
{% endmacro %}

{# ── AJAX toast element ── #}
<div id="ajax-toast"></div>

{# ═══════════════════════════════════ FEED ═══════════════════════════════════ #}
<div class="ss-feed-wrap">
<div class="ss-feed-inner">

    {# Flash messages (server-side) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="ss-toast-{{ label == 'success' ? 'success' : 'error' }}">
                <i class="bi bi-{{ label == 'success' ? 'check-circle-fill' : 'exclamation-circle-fill' }}" style="font-size:18px;flex-shrink:0;"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    {# ──── Welcome Banner ──── #}
    <div class="ss-welcome">
        <div>
            <div class="ss-welcome-title">Welcome back, {{ currentUser.fullName|split(' ')[0] }}! 👋</div>
            <div class="ss-welcome-sub">What's on your mind today?</div>
        </div>
        <div class="ss-welcome-icon-wrap"><i class="bi bi-heart-fill"></i></div>
    </div>

    {# ──── Create Post Card ──── #}
    <div class="ss-card" id="createPostCard">
        <form action="{{ path('post_new') }}" method="post" enctype="multipart/form-data" id="createPostForm">
            <input type="hidden" name="post[_token]" value="{{ csrf_token('post') }}">

            <div class="d-flex gap-3 align-items-start mb-3">
                <div class="ss-create-avatar"><i class="bi bi-pen-fill"></i></div>
                <textarea name="post[content]"
                          class="ss-textarea" rows="3"
                          placeholder="What's on your mind?"></textarea>
            </div>

            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="ss-vis-label">Who can see this?</span>
                <button type="button" class="ss-vis-btn {{ currentUser.role != 'PATIENT' ? 'active' : '' }}"
                        onclick="setVisibility(this,'PUBLIC')">
                    <i class="bi bi-globe2"></i> Public
                </button>
                {% if currentUser.role == 'PATIENT' %}
                <button type="button" class="ss-vis-btn active"
                        onclick="setVisibility(this,'PATIENTS_ONLY')">
                    <i class="bi bi-people-fill"></i> Patients Only
                </button>
                {% endif %}
                <input type="hidden" name="post[visibility]" id="visibilityInput"
                       value="{{ currentUser.role == 'PATIENT' ? 'PATIENTS_ONLY' : 'PUBLIC' }}">
            </div>

            <div class="mb-3">
                <div class="ss-up-grid" id="ss-up-grid"></div>
            </div>
            <input type="file" id="ss-up-input" style="display:none;" accept="image/*,video/*" multiple>

            <div class="d-flex justify-content-end align-items-center">
                <button type="submit" class="ss-post-btn">Post</button>
            </div>
        </form>
    </div>

    {# ──── Filter Bar ──── #}
    <div class="ss-filters">
        <span class="ss-filter-label">Filter</span>
        <a href="#" class="ss-filter-btn {{ filter is not defined or filter == '' ? 'active' : '' }}"
           data-filter="">All Posts</a>
        <a href="#" class="ss-filter-btn {{ filter is defined and filter == 'PUBLIC' ? 'active' : '' }}"
           data-filter="PUBLIC">
            <i class="bi bi-globe2"></i> Public
        </a>
        {% if currentUser.role == 'PATIENT' %}
        <a href="#" class="ss-filter-btn {{ filter is defined and filter == 'PATIENTS_ONLY' ? 'active' : '' }}"
           data-filter="PATIENTS_ONLY">
            <i class="bi bi-people-fill"></i> Patients Only
        </a>
        {% endif %}
        <div class="ss-latest-tag ms-auto" style="gap:10px;">
            <i class="bi bi-clock"></i>
            <select id="sortSelect"
                    style="background:none;border:none;font-size:12px;color:var(--gray-400);cursor:pointer;outline:none;font-family:inherit;">
                <option value="newest" {{ sort is defined and sort == 'newest' ? 'selected' : '' }}>⬇ Newest</option>
                <option value="oldest" {{ sort is defined and sort == 'oldest' ? 'selected' : '' }}>⬆ Oldest</option>
            </select>
        </div>
    </div>

    {# ──── Posts ──── #}
    <div id="posts-container">
    {% if posts is empty %}
        <div class="ss-empty-state">
            <div class="ss-empty-icon-wrap"><i class="bi bi-chat-slash-fill"></i></div>
            <div class="ss-empty-title">No posts yet</div>
            <div class="ss-empty-sub">Be the first to share something!</div>
        </div>
    {% else %}
        {% for post in posts %}
            {% if not post.isDeleted %}
            {% set author = post.author %}
            {% set userReaction = post.getUserReaction(currentUser) %}
            {% set reactionCounts = post.getReactionCounts() %}
            {% set totalReactions = post.getTotalReactions() %}
            {% set topLevelComments = post.comments|filter(c => not c.isDeleted and c.parentComment is null) %}

            <div class="ss-post-card" id="post-{{ post.id }}">

                {# ── Post Header ── #}
                <div class="ss-post-header">
                    <div class="ss-post-avatar" style="{{ _self.avatarBg(author.role) }}">
                        {% if author.profilePicture %}
                            <img src="{{ author.profilePicture }}" alt="" style="width:40px;height:40px;border-radius:50%;object-fit:cover;">
                        {% else %}
                            {{ _self.initials(author.fullName) }}
                        {% endif %}
                    </div>
                    <div>
                        <div>
                            <span class="ss-author-name">{{ author.fullName }}</span>
                            <span class="ss-post-time">{{ _self.timeAgo(post.createdAt) }}</span>
                        </div>
                        <div class="ss-author-role {{ _self.roleClass(author.role) }}">
                            {{ author.role }}
                            &nbsp;·&nbsp;
                            <span class="ss-vis-badge ss-vis-badge-{{ post.visibility|lower }}">
                                <i class="bi bi-{{ post.visibility == 'PUBLIC' ? 'globe2' : 'people-fill' }}"></i>
                                {{ post.visibility == 'PUBLIC' ? 'Public' : 'Patients Only' }}
                            </span>
                        </div>
                    </div>

                    {% if currentUser.id == author.id %}
                    <div class="dropdown" style="margin-left:auto;">
                        <button class="ss-post-menu-btn" data-bs-toggle="dropdown" aria-expanded="false">⋯</button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:12px;border:1px solid #e5e7eb;padding:6px 0;">
                            <li>
                                <button class="dropdown-item d-flex align-items-center gap-2"
                                        onclick="openEditModal({{ post.id }})"
                                        style="font-size:13px;padding:10px 16px;">
                                    <i class="bi bi-pencil-fill text-secondary"></i> Edit post
                                </button>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <button class="dropdown-item d-flex align-items-center gap-2 text-danger"
                                        onclick="confirmDelete({{ post.id }})"
                                        style="font-size:13px;padding:10px 16px;">
                                    <i class="bi bi-trash-fill"></i> Delete post
                                </button>
                            </li>
                        </ul>
                    </div>
                    {% endif %}
                </div>

                {# ── Post content ── #}
                <div class="ss-post-view" id="post-view-{{ post.id }}">
                    <div class="ss-post-content">{{ post.content }}</div>

                    {% if post.mediaList is not empty %}
                        {% set mediaCount = post.mediaList|length %}
                        {% if mediaCount == 1 %}{% set gridClass = 'count-1' %}
                        {% elseif mediaCount == 2 %}{% set gridClass = 'count-2' %}
                        {% elseif mediaCount == 3 %}{% set gridClass = 'count-3' %}
                        {% elseif mediaCount == 4 %}{% set gridClass = 'count-4' %}
                        {% else %}{% set gridClass = 'count-5plus' %}
                        {% endif %}
                        {% set displayList = mediaCount <= 4 ? post.mediaList : post.mediaList|slice(0, 4) %}
                        {% set hiddenCount = mediaCount > 4 ? mediaCount - 4 : 0 %}
                        <div class="ss-media-grid {{ gridClass }} mb-3">
                            {% for media in displayList %}
                                {% set isLast = loop.last and hiddenCount > 0 %}
                                <div class="ss-media-cell">
                                    {% if media.mediaType == 'VIDEO' %}
                                        <video controls><source src="{{ media.mediaUrl }}"></video>
                                    {% else %}
                                        <img src="{{ media.mediaUrl }}" alt="Post media" loading="lazy">
                                    {% endif %}
                                    {% if isLast %}
                                        <div class="ss-media-more-overlay">+{{ hiddenCount }}</div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# ── Reactions Preview ── #}
                    <div class="ss-reactions-preview">
                        <div class="d-flex align-items-center gap-2">
                            {% if totalReactions == 0 %}
                                <span class="ss-no-reactions">Be the first to react</span>
                            {% else %}
                                <div class="ss-reaction-icons">
                                    {% if reactionCounts['LIKE'] is defined and reactionCounts['LIKE'] > 0 %}
                                        <div class="ss-reaction-icon-wrap">👍</div>
                                    {% endif %}
                                    {% if reactionCounts['LOVE'] is defined and reactionCounts['LOVE'] > 0 %}
                                        <div class="ss-reaction-icon-wrap">❤️</div>
                                    {% endif %}
                                    {% if reactionCounts['SUPPORT'] is defined and reactionCounts['SUPPORT'] > 0 %}
                                        <div class="ss-reaction-icon-wrap">💙</div>
                                    {% endif %}
                                </div>
                                <span class="ss-reaction-count">
                                    {% if totalReactions == 1 %}1 reaction{% else %}{{ totalReactions }} reactions{% endif %}
                                </span>
                            {% endif %}
                        </div>
                        <button class="ss-comment-toggle-btn" onclick="toggleComments({{ post.id }})">
                            {{ topLevelComments|length }}
                            comment{% if topLevelComments|length != 1 %}s{% endif %}
                        </button>
                    </div>

                    {# ── Reaction Buttons Bar ── #}
                    <div class="ss-reaction-bar">
                        {% set reactions = [
                            {type: 'LIKE',    emoji: '👍', label: 'Like'},
                            {type: 'LOVE',    emoji: '❤️', label: 'Love'},
                            {type: 'SUPPORT', emoji: '💙', label: 'Support'},
                        ] %}
                        {% for rxn in reactions %}
                            {% set isActive = userReaction == rxn.type %}
                            {% set count = reactionCounts[rxn.type] is defined ? reactionCounts[rxn.type] : 0 %}
                            <form action="{{ isActive ? path('reaction_delete', {postId: post.id, userId: currentUser.id}) : path('reaction_new') }}" method="post">
                                {% if not isActive %}
                                    <input type="hidden" name="reaction[post]" value="{{ post.id }}">
                                    <input type="hidden" name="reaction[reactionType]" value="{{ rxn.type }}">
                                    <input type="hidden" name="reaction[_token]" value="{{ csrf_token('reaction') }}">
                                {% else %}
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id ~ '_' ~ currentUser.id) }}">
                                {% endif %}
                                <button type="submit" class="ss-rxn-btn {{ isActive ? 'active' : '' }}">
                                    {{ rxn.emoji }} {{ rxn.label }}
                                    {% if count > 0 %}<span class="rxn-count">{{ count }}</span>{% endif %}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                </div>{# end ss-post-view #}

                {# ── Comments Section ── #}
                <div class="ss-comments-section" id="comments-section-{{ post.id }}" style="display:none;">
                    <div class="ss-comments-header">
                        <span class="ss-comments-title">💬 {{ topLevelComments|length }} Comment{% if topLevelComments|length != 1 %}s{% endif %}</span>
                        <button class="ss-hide-btn" onclick="toggleComments({{ post.id }})">Hide</button>
                    </div>

                    {% if topLevelComments is empty %}
                        <div class="ss-no-comments">
                            <p>No comments yet</p>
                            <small>Be the first to comment</small>
                        </div>
                    {% else %}
                        {% for comment in topLevelComments %}
                            <div class="ss-comment" id="comment-{{ comment.id }}">
                                <div class="ss-comment-avatar" style="{{ _self.avatarBg(comment.author.role) }}">
                                    {{ _self.initials(comment.author.fullName) }}
                                </div>
                                <div class="ss-comment-body">
                                    <div>
                                        <span class="ss-comment-author">{{ comment.author.fullName }}</span>
                                        <span class="ss-comment-time">{{ _self.timeAgo(comment.createdAt) }}</span>
                                        {% if comment.isEdited %}<span class="ss-comment-edited">(edited)</span>{% endif %}
                                    </div>
                                    <div class="ss-comment-text" id="comment-text-{{ comment.id }}">{{ comment.content }}</div>

                                    <div class="ss-inline-edit" id="comment-edit-{{ comment.id }}">
                                        <form action="{{ path('comment_edit', {id: comment.id}) }}" method="post" style="flex:1;display:flex;gap:8px;">
                                            <input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
                                            <textarea name="comment[content]" rows="2" style="flex:1;border:1.5px solid #4f46e5;border-radius:10px;padding:8px 12px;font-size:13px;font-family:inherit;outline:none;resize:none;background:#ede9fe;">{{ comment.content }}</textarea>
                                            <div style="display:flex;flex-direction:column;gap:4px;">
                                                <button type="submit" class="ss-inline-edit-save">Save</button>
                                                <button type="button" class="ss-inline-edit-cancel" onclick="toggleEditComment({{ comment.id }})">Cancel</button>
                                            </div>
                                        </form>
                                    </div>

                                    <div class="ss-comment-actions">
                                        <button class="ss-comment-action-btn ss-reply-btn"
                                                onclick="toggleReplyForm({{ comment.id }})">Reply</button>
                                        {% if currentUser.id == comment.author.id %}
                                            <button class="ss-comment-action-btn ss-edit-btn"
                                                    onclick="toggleEditComment({{ comment.id }})">Edit</button>
                                            <form action="{{ path('comment_delete', {id: comment.id}) }}" method="post" style="display:inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                                                <button type="submit" class="ss-comment-action-btn ss-delete-btn"
                                                        onclick="return confirm('Delete this comment?')">Delete</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {% set replies = comment.replies|filter(r => not r.isDeleted) %}
                            {% if replies is not empty %}
                                <button class="ss-replies-toggle" id="replies-toggle-{{ comment.id }}"
                                        onclick="toggleReplies({{ comment.id }})">
                                    ▶ Show replies ({{ replies|length }})
                                </button>
                                <div class="ss-replies-block" id="replies-block-{{ comment.id }}" style="display:none;">
                                    {% for reply in replies %}
                                        <div class="ss-reply-indicator">↳ replying to {{ comment.author.fullName|split(' ')[0] }}</div>
                                        <div class="ss-comment" id="comment-{{ reply.id }}">
                                            <div class="ss-comment-avatar" style="{{ _self.avatarBg(reply.author.role) }}">
                                                {{ _self.initials(reply.author.fullName) }}
                                            </div>
                                            <div class="ss-comment-body">
                                                <div>
                                                    <span class="ss-comment-author">{{ reply.author.fullName }}</span>
                                                    <span class="ss-comment-time">{{ _self.timeAgo(reply.createdAt) }}</span>
                                                    {% if reply.isEdited %}<span class="ss-comment-edited">(edited)</span>{% endif %}
                                                </div>
                                                <div class="ss-comment-text" id="comment-text-{{ reply.id }}">{{ reply.content }}</div>

                                                <div class="ss-inline-edit" id="comment-edit-{{ reply.id }}">
                                                    <form action="{{ path('comment_edit', {id: reply.id}) }}" method="post" style="flex:1;display:flex;gap:8px;">
                                                        <input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
                                                        <textarea name="comment[content]" rows="2" style="flex:1;border:1.5px solid #4f46e5;border-radius:10px;padding:8px 12px;font-size:13px;font-family:inherit;outline:none;resize:none;background:#ede9fe;">{{ reply.content }}</textarea>
                                                        <div style="display:flex;flex-direction:column;gap:4px;">
                                                            <button type="submit" class="ss-inline-edit-save">Save</button>
                                                            <button type="button" class="ss-inline-edit-cancel" onclick="toggleEditComment({{ reply.id }})">Cancel</button>
                                                        </div>
                                                    </form>
                                                </div>

                                                <div class="ss-comment-actions">
                                                    {% if currentUser.id == reply.author.id %}
                                                        <button class="ss-comment-action-btn ss-edit-btn"
                                                                onclick="toggleEditComment({{ reply.id }})">Edit</button>
                                                        <form action="{{ path('comment_delete', {id: reply.id}) }}" method="post" style="display:inline;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reply.id) }}">
                                                            <button type="submit" class="ss-comment-action-btn ss-delete-btn"
                                                                    onclick="return confirm('Delete this reply?')">Delete</button>
                                                        </form>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}

                                    <div class="ss-comment-input-wrap" style="padding-left:0;margin-top:10px;">
                                        <form action="{{ path('comment_new') }}" method="post" style="display:flex;gap:8px;flex:1;">
                                            <input type="hidden" name="comment[post]" value="{{ post.id }}">
                                            <input type="hidden" name="comment[parentComment]" value="{{ comment.id }}">
                                            <input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
                                            <input type="text" name="comment[content]" class="ss-comment-input" placeholder="Write a reply…">
                                            <button type="submit" class="ss-comment-submit-btn">Reply</button>
                                        </form>
                                    </div>
                                </div>
                            {% endif %}

                            <div class="ss-comment-input-wrap" id="reply-form-{{ comment.id }}" style="display:none;padding-left:42px;">
                                <form action="{{ path('comment_new') }}" method="post" style="display:flex;gap:8px;flex:1;">
                                    <input type="hidden" name="comment[post]" value="{{ post.id }}">
                                    <input type="hidden" name="comment[parentComment]" value="{{ comment.id }}">
                                    <input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
                                    <input type="text" name="comment[content]" class="ss-comment-input"
                                           placeholder="Write a reply…" id="reply-input-{{ comment.id }}">
                                    <button type="submit" class="ss-comment-submit-btn">Reply</button>
                                </form>
                            </div>

                            <hr class="ss-comment-sep" style="border:none;border-top:1px solid var(--gray-100);margin:4px 0;opacity:.4;">
                        {% endfor %}
                    {% endif %}

                    <div class="ss-comment-input-wrap mt-3">
                        <form action="{{ path('comment_new') }}" method="post" style="display:flex;gap:8px;flex:1;">
                            <input type="hidden" name="comment[post]" value="{{ post.id }}">
                            <input type="hidden" name="comment[parentComment]" value="">
                            <input type="hidden" name="comment[_token]" value="{{ csrf_token('comment') }}">
                            <input type="text" name="comment[content]" class="ss-comment-input" placeholder="Write a comment…">
                            <button type="submit" class="ss-comment-submit-btn">Post</button>
                        </form>
                    </div>
                </div>{# end comments-section #}

            </div>{# end ss-post-card #}
            {% endif %}
        {% endfor %}
    {% endif %}
    </div>{# end posts-container #}

</div>{# end ss-feed-inner #}
</div>{# end ss-feed-wrap #}

{# ── Delete confirm modals ── #}
{% for post in posts %}
    {% if not post.isDeleted and currentUser.id == post.author.id %}
    <div class="ss-confirm-overlay" id="delete-confirm-{{ post.id }}">
        <div class="ss-confirm-box">
            <div class="ss-confirm-title">Delete Post</div>
            <div class="ss-confirm-sub">Are you sure? This action cannot be undone.</div>
            <div class="ss-confirm-btns">
                <button class="ss-confirm-cancel" onclick="hideConfirm({{ post.id }})">Cancel</button>
                <form action="{{ path('post_delete', {id: post.id}) }}" method="post" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                    <button type="submit" class="ss-confirm-delete">Delete</button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}
{% endfor %}

{# ── Edit Post Modals ── #}
{% for post in posts %}
    {% if not post.isDeleted and currentUser.id == post.author.id %}
    <div class="ss-modal-overlay" id="edit-modal-{{ post.id }}">
        <div class="ss-modal">
            <div class="ss-modal-header">
                <div class="ss-modal-icon-wrap"><i class="bi bi-pencil-fill"></i></div>
                <div>
                    <div class="ss-modal-title">Edit Post</div>
                    <div class="ss-modal-subtitle">Make changes to your post below</div>
                </div>
                <button class="ss-modal-close" onclick="closeEditModal({{ post.id }})">&#x2715;</button>
            </div>
            <div class="ss-modal-divider"></div>

            <div class="ss-modal-body">
                <form action="{{ path('post_edit', {id: post.id}) }}"
                      method="post" enctype="multipart/form-data"
                      id="edit-form-{{ post.id }}">
                    <input type="hidden" name="post[_token]" value="{{ csrf_token('post') }}">

                    <div>
                        <span class="ss-modal-section-label">Caption</span>
                        <textarea name="post[content]" class="ss-textarea" rows="4"
                                  placeholder="What's on your mind?">{{ post.content }}</textarea>
                    </div>

                    <div>
                        <span class="ss-modal-section-label">Visibility</span>
                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="ss-vis-btn {{ post.visibility == 'PUBLIC' ? 'active' : '' }}"
                                    onclick="setEditModalVisibility(this, 'PUBLIC', {{ post.id }})">
                                <i class="bi bi-globe2"></i> Public
                            </button>
                            {% if currentUser.role == 'PATIENT' %}
                            <button type="button"
                                    class="ss-vis-btn {{ post.visibility == 'PATIENTS_ONLY' ? 'active' : '' }}"
                                    onclick="setEditModalVisibility(this, 'PATIENTS_ONLY', {{ post.id }})">
                                <i class="bi bi-people-fill"></i> Patients Only
                            </button>
                            {% endif %}
                            <input type="hidden" name="post[visibility]"
                                   id="modal-vis-{{ post.id }}" value="{{ post.visibility }}">
                        </div>
                    </div>

                    <div>
                        <span class="ss-modal-section-label">Current media</span>
                        <input type="hidden" name="post[keepMedia]"
                               id="keep-media-input-{{ post.id }}"
                               value="{{ post.mediaList|map(m => m.id)|join(',') }}">
                        <div class="ss-modal-media-grid" id="modal-media-{{ post.id }}">
                            {% if post.mediaList is empty %}
                                <span class="ss-modal-no-media">No media attached to this post.</span>
                            {% else %}
                                {% for media in post.mediaList %}
                                    <div class="ss-modal-media-item"
                                         id="modal-media-item-{{ media.id }}"
                                         data-media-id="{{ media.id }}">
                                        {% if media.mediaType == 'VIDEO' %}
                                            <video><source src="{{ media.mediaUrl }}"></video>
                                        {% else %}
                                            <img src="{{ media.mediaUrl }}" alt="media">
                                        {% endif %}
                                        <button type="button" class="ss-modal-media-del" title="Remove"
                                                onclick="removeExistingMedia(this, {{ media.id }}, {{ post.id }})">
                                            &#x2715;
                                        </button>
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>

                    <div>
                        <span class="ss-modal-section-label">Add new media</span>
                        <div class="ss-up-grid" id="modal-new-media-{{ post.id }}"></div>
                        <input type="file" id="modal-file-{{ post.id }}" style="display:none"
                               accept="image/*,video/*" multiple>
                        <button type="button" class="ss-modal-add-media-btn"
                                onclick="document.getElementById('modal-file-{{ post.id }}').click()">
                            <i class="bi bi-camera-fill"></i> Add more media
                        </button>
                    </div>
                </form>
            </div>

            <div class="ss-modal-footer">
                <button class="ss-modal-cancel" onclick="closeEditModal({{ post.id }})">Cancel</button>
                <button class="ss-modal-save" onclick="submitEditModal({{ post.id }})">
                    <i class="bi bi-check-lg me-1"></i> Save changes
                </button>
            </div>
        </div>
    </div>
    {% endif %}
{% endfor %}

{% endblock %}

{% block javascripts %}
<script>
/* ══════════════════════════════════════════════════════════
   AJAX TOAST
══════════════════════════════════════════════════════════ */
let toastTimer;
function showToast(message, type = 'success') {
    const el = document.getElementById('ajax-toast');
    el.className = 'toast-' + (type === 'success' ? 'success' : 'danger');
    el.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'exclamation-circle-fill'}" style="font-size:18px;flex-shrink:0;"></i><span>${message}</span>`;
    el.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => el.classList.remove('show'), 3500);
}

/* ══════════════════════════════════════════════════════════
   AJAX — FETCH POSTS (search / filter / sort)
══════════════════════════════════════════════════════════ */
const postsContainer = document.getElementById('posts-container');

function fetchPosts(params = {}) {
    const url = new URL('/feed', window.location.origin);
    Object.entries(params).forEach(([k, v]) => { if (v !== '' && v !== null && v !== undefined) url.searchParams.set(k, v); });
    window.history.pushState({}, '', url.toString());
    postsContainer.style.opacity = '0.5';
    fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => { postsContainer.innerHTML = data.html; postsContainer.style.opacity = '1'; })
        .catch(() => { postsContainer.style.opacity = '1'; showToast('Failed to load posts.', 'danger'); });
}

function getCurrentParams() {
    const p = new URLSearchParams(window.location.search);
    return { filter: p.get('filter') || '', search: p.get('search') || '', sort: p.get('sort') || 'newest' };
}

/* Filter buttons */
document.querySelectorAll('.ss-filter-btn[data-filter]').forEach(btn => {
    btn.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelectorAll('.ss-filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        fetchPosts({ ...getCurrentParams(), filter: this.dataset.filter });
    });
});

/* Sort select */
document.getElementById('sortSelect').addEventListener('change', function () {
    fetchPosts({ ...getCurrentParams(), sort: this.value });
});

/* ══════════════════════════════════════════════════════════
   AJAX — CREATE POST
══════════════════════════════════════════════════════════ */
document.getElementById('createPostForm').addEventListener('submit', function (e) {
    e.preventDefault();
    const form = this;
    const submitBtn = form.querySelector('.ss-post-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Posting…';
    fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Post';
            if (data.success) {
                form.querySelector('textarea').value = '';
                form.querySelectorAll('.ss-vis-btn').forEach(b => b.classList.remove('active'));
                form.querySelector('.ss-vis-btn').classList.add('active');
                document.getElementById('ss-up-grid').innerHTML = '';
                const oldReal = form.querySelector('input.ss-real-files');
                if (oldReal) oldReal.remove();
                fetchPosts(getCurrentParams());
                showToast('Post created!', 'success');
            } else {
                showToast(data.errors ? data.errors.join(' ') : (data.error || 'Could not create post.'), 'danger');
            }
        })
        .catch(() => { submitBtn.disabled = false; submitBtn.textContent = 'Post'; showToast('Network error.', 'danger'); });
});

/* ══════════════════════════════════════════════════════════
   AJAX — EDIT POST
══════════════════════════════════════════════════════════ */
function submitEditModal(postId) {
    const form = document.getElementById('edit-form-' + postId);
    const saveBtn = document.querySelector('#edit-modal-' + postId + ' .ss-modal-save');
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Saving…';
    fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(r => r.json())
        .then(data => {
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Save changes';
            if (data.success) { closeEditModal(postId); fetchPosts(getCurrentParams()); showToast('Post updated!', 'success'); }
            else showToast(data.errors ? data.errors.join(' ') : (data.error || 'Could not update post.'), 'danger');
        })
        .catch(() => { saveBtn.disabled = false; saveBtn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Save changes'; showToast('Network error.', 'danger'); });
}

/* ══════════════════════════════════════════════════════════
   AJAX — COMMENTS + REACTIONS (event delegation)
══════════════════════════════════════════════════════════ */
document.addEventListener('submit', function (e) {
    const form = e.target;

    if (form.action && form.action.includes('/comments/new')) {
        e.preventDefault();
        const input = form.querySelector('input[name="comment[content]"], textarea[name="comment[content]"]');
        fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(data => {
                if (data.success) { if (input) input.value = ''; fetchPosts(getCurrentParams()); }
                else showToast(data.errors ? data.errors.join(' ') : (data.error || 'Could not post comment.'), 'danger');
            })
            .catch(() => showToast('Network error.', 'danger'));
        return;
    }

    const editMatch = form.action && form.action.match(/\/comments\/(\d+)\/edit/);
    if (editMatch) {
        e.preventDefault();
        const commentId = editMatch[1];
        fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(data => {
                if (data.success) { const textEl = document.getElementById('comment-text-' + commentId); if (textEl) textEl.textContent = data.content; toggleEditComment(commentId); }
                else showToast(data.errors ? data.errors.join(' ') : 'Could not update comment.', 'danger');
            })
            .catch(() => showToast('Network error.', 'danger'));
        return;
    }

    if (form.action && form.action.includes('/reactions')) {
        e.preventDefault();
        fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(data => { if (data.success) fetchPosts(getCurrentParams()); })
            .catch(() => showToast('Network error.', 'danger'));
    }
});

/* ══════════════════════════════════════════════════════════
   VISIBILITY SELECTORS
══════════════════════════════════════════════════════════ */
function setVisibility(btn, value) {
    document.querySelectorAll('#createPostCard .ss-vis-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('visibilityInput').value = value;
}
function setEditModalVisibility(btn, value, postId) {
    const modal = document.getElementById('edit-modal-' + postId);
    modal.querySelectorAll('.ss-vis-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('modal-vis-' + postId).value = value;
}

/* ══════════════════════════════════════════════════════════
   EDIT POST MODAL
══════════════════════════════════════════════════════════ */
function openEditModal(postId) {
    document.querySelectorAll('.dropdown-menu.show').forEach(m => m.classList.remove('show'));
    document.getElementById('edit-modal-' + postId).classList.add('show');
    document.body.style.overflow = 'hidden';
    initModalUploader(postId);
}
function closeEditModal(postId) {
    document.getElementById('edit-modal-' + postId).classList.remove('show');
    document.body.style.overflow = '';
}
document.addEventListener('click', function (e) {
    if (e.target.classList.contains('ss-modal-overlay')) {
        e.target.classList.remove('show');
        document.body.style.overflow = '';
    }
});
function updateKeepMediaInput(postId) {
    const grid  = document.getElementById('modal-media-' + postId);
    const input = document.getElementById('keep-media-input-' + postId);
    if (!grid || !input) return;
    const ids = [];
    grid.querySelectorAll('.ss-modal-media-item:not(.ss-media-removed)').forEach(item => ids.push(item.dataset.mediaId));
    input.value = ids.join(',');
}
function removeExistingMedia(btn, mediaId, postId) {
    const item = document.getElementById('modal-media-item-' + mediaId);
    if (item) { item.style.opacity = '0.35'; item.classList.add('ss-media-removed'); }
    btn.innerHTML = '↩'; btn.title = 'Undo remove';
    btn.onclick = function () { restoreExistingMedia(btn, mediaId, postId); };
    updateKeepMediaInput(postId);
}
function restoreExistingMedia(btn, mediaId, postId) {
    const item = document.getElementById('modal-media-item-' + mediaId);
    if (item) { item.style.opacity = '1'; item.classList.remove('ss-media-removed'); }
    btn.innerHTML = '&#x2715;'; btn.title = 'Remove';
    btn.onclick = function () { removeExistingMedia(btn, mediaId, postId); };
    updateKeepMediaInput(postId);
}
const modalUploaders = {};
function initModalUploader(postId) {
    if (modalUploaders[postId]) return;
    const grid    = document.getElementById('modal-new-media-' + postId);
    const trigger = document.getElementById('modal-file-' + postId);
    const form    = document.getElementById('edit-form-' + postId);
    if (!grid || !trigger || !form) return;
    let files = [];
    function syncInput() {
        const old = form.querySelector('input.ss-modal-real-files');
        if (old) old.remove();
        if (files.length === 0) return;
        const dt = new DataTransfer();
        files.forEach(f => dt.items.add(f));
        const real = document.createElement('input');
        real.type = 'file'; real.name = 'post[mediaFiles][]';
        real.multiple = true; real.className = 'ss-modal-real-files';
        real.style.display = 'none';
        form.appendChild(real);
        real.files = dt.files;
    }
    function render() {
        grid.innerHTML = '';
        if (files.length === 0) { const e = document.createElement('span'); e.className = 'ss-up-empty'; e.textContent = 'No new files selected.'; grid.appendChild(e); }
        files.forEach((file, i) => {
            const thumb = document.createElement('div'); thumb.className = 'ss-up-thumb';
            if (file.type.startsWith('image/')) { const img = document.createElement('img'); const url = URL.createObjectURL(file); img.src = url; img.onload = () => URL.revokeObjectURL(url); thumb.appendChild(img); }
            else { const icon = document.createElement('span'); icon.className = 'ss-up-vid-icon'; icon.textContent = '🎬'; thumb.appendChild(icon); }
            const rmBtn = document.createElement('button'); rmBtn.type = 'button'; rmBtn.className = 'ss-up-remove'; rmBtn.innerHTML = '&#x2715;';
            rmBtn.addEventListener('click', () => { files.splice(i, 1); render(); syncInput(); });
            thumb.appendChild(rmBtn); grid.appendChild(thumb);
        });
        const addBtn = document.createElement('div'); addBtn.className = 'ss-up-add-btn';
        addBtn.innerHTML = '<span>+</span><span class="ss-up-add-label">Add</span>';
        addBtn.addEventListener('click', () => { trigger.value = ''; trigger.click(); });
        grid.appendChild(addBtn);
    }
    trigger.addEventListener('change', () => { Array.from(trigger.files).forEach(f => files.push(f)); render(); syncInput(); });
    modalUploaders[postId] = true;
    render();
}

/* ══════════════════════════════════════════════════════════
   COMMENTS UI HELPERS
══════════════════════════════════════════════════════════ */
function toggleEditComment(commentId) {
    const textEl = document.getElementById('comment-text-' + commentId);
    const editEl = document.getElementById('comment-edit-' + commentId);
    if (textEl) textEl.style.display = textEl.style.display === 'none' ? '' : 'none';
    if (editEl) editEl.classList.toggle('show');
}
function toggleComments(postId) {
    const section = document.getElementById('comments-section-' + postId);
    if (section) section.style.display = section.style.display === 'none' ? 'block' : 'none';
}
function toggleReplyForm(commentId) {
    document.querySelectorAll('[id^="reply-form-"]').forEach(el => { if (el.id !== 'reply-form-' + commentId) el.style.display = 'none'; });
    const form = document.getElementById('reply-form-' + commentId);
    if (form.style.display === 'none') { form.style.display = 'flex'; const input = document.getElementById('reply-input-' + commentId); if (input) input.focus(); }
    else form.style.display = 'none';
}
function toggleReplies(commentId) {
    const block  = document.getElementById('replies-block-' + commentId);
    const toggle = document.getElementById('replies-toggle-' + commentId);
    if (block.style.display === 'none') { block.style.display = 'block'; toggle.textContent = toggle.textContent.replace('▶', '▼').replace('Show', 'Hide'); }
    else { block.style.display = 'none'; toggle.textContent = toggle.textContent.replace('▼', '▶').replace('Hide', 'Show'); }
}

/* ══════════════════════════════════════════════════════════
   DELETE CONFIRM MODAL
══════════════════════════════════════════════════════════ */
function confirmDelete(postId) { document.getElementById('delete-confirm-' + postId).classList.add('show'); }
function hideConfirm(postId)   { document.getElementById('delete-confirm-' + postId).classList.remove('show'); }
document.querySelectorAll('.ss-confirm-overlay').forEach(el => {
    el.addEventListener('click', function (e) { if (e.target === this) this.classList.remove('show'); });
});

/* ══════════════════════════════════════════════════════════
   CREATE POST — media upload manager
══════════════════════════════════════════════════════════ */
(function () {
    const grid    = document.getElementById('ss-up-grid');
    const trigger = document.getElementById('ss-up-input');
    const form    = document.getElementById('createPostForm');
    if (!grid || !trigger || !form) return;
    let files = [];
    function syncInput() {
        const old = form.querySelector('input.ss-real-files');
        if (old) old.remove();
        if (files.length === 0) return;
        const dt = new DataTransfer();
        files.forEach(f => dt.items.add(f));
        const real = document.createElement('input');
        real.type = 'file'; real.name = 'post[mediaFiles][]';
        real.multiple = true; real.className = 'ss-real-files';
        real.style.display = 'none';
        form.appendChild(real);
        real.files = dt.files;
    }
    function render() {
        grid.innerHTML = '';
        if (files.length === 0) { const e = document.createElement('span'); e.className = 'ss-up-empty'; e.textContent = 'No media attached yet.'; grid.appendChild(e); }
        files.forEach((file, i) => {
            const thumb = document.createElement('div'); thumb.className = 'ss-up-thumb';
            if (file.type.startsWith('image/')) { const img = document.createElement('img'); const url = URL.createObjectURL(file); img.src = url; img.onload = () => URL.revokeObjectURL(url); thumb.appendChild(img); }
            else { const icon = document.createElement('span'); icon.className = 'ss-up-vid-icon'; icon.textContent = '🎬'; thumb.appendChild(icon); }
            const removeBtn = document.createElement('button'); removeBtn.type = 'button'; removeBtn.className = 'ss-up-remove';
            removeBtn.title = 'Remove'; removeBtn.innerHTML = '&#x2715;';
            removeBtn.addEventListener('click', () => { files.splice(i, 1); render(); syncInput(); });
            thumb.appendChild(removeBtn); grid.appendChild(thumb);
        });
        const addBtn = document.createElement('div'); addBtn.className = 'ss-up-add-btn'; addBtn.title = 'Add media';
        addBtn.innerHTML = '<span>+</span><span class="ss-up-add-label">Add</span>';
        addBtn.addEventListener('click', () => { trigger.value = ''; trigger.click(); });
        grid.appendChild(addBtn);
    }
    trigger.addEventListener('change', () => { Array.from(trigger.files).forEach(f => files.push(f)); render(); syncInput(); });
    render();
})();
</script>
{% endblock %}
