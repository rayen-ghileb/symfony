{% extends 'base_auth.html.twig' %}

{% block title %}Sign In - Safe Space{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card" style="max-width: 450px;">
        <!-- Logo and Title -->
        <div class="text-center mb-4">
            <h1 class="display-4 fw-bold text-primary">Safe Space</h1>
            <p class="text-muted">Mental Health Consultation System</p>
        </div>

        <!-- Login Form -->
        <div class="auth-form">
            <h3 class="h5 mb-3 fw-semibold">Welcome Back!</h3>

            {% if error %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" data-controller="login-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <!-- Email Field -->
                <div class="mb-3">
                    <label for="username" class="form-label">Email</label>
                    <input type="email" 
                           id="username" 
                           name="_username" 
                           class="form-control form-control-lg"
                           value="{{ last_username }}" 
                           placeholder="Enter your email"
                           required 
                           autofocus>
                </div>

                <!-- Password Field with Toggle -->
                <div class="mb-3" data-controller="password-toggle">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password" 
                               id="password" 
                               name="_password" 
                               class="form-control form-control-lg"
                               placeholder="Enter your password"
                               required>
                        <button class="btn btn-outline-secondary" 
                                type="button"
                                data-action="password-toggle#toggle">
                            <i class="bi bi-eye-slash" data-password-toggle-target="icon"></i>
                        </button>
                    </div>
                </div>

                <!-- Remember Me -->
                <div class="mb-3 form-check">
                    <input type="checkbox" 
                           class="form-check-input" 
                           id="remember_me" 
                           name="_remember_me">
                    <label class="form-check-label" for="remember_me">
                        Remember me
                    </label>
                </div>

                <!-- Login Button with Loading State -->
                <button type="submit" 
                        class="btn btn-primary btn-lg w-100 mb-3"
                        data-login-form-target="submitBtn"
                        data-action="login-form#submit">
                    <span class="normal-text">Sign In</span>
                    <span class="spinner-border spinner-border-sm d-none" 
                          data-login-form-target="spinner"></span>
                </button>

                <!-- Registration Links -->
                <div class="text-center mb-2">
                    <p class="mb-1">New patient? 
                        <a href="{{ path('app_register_patient') }}" class="text-decoration-none">
                            Register as Patient
                        </a>
                    </p>
                    <p>New psychiatrist? 
                        <a href="{{ path('app_register_psychiatrist') }}" class="text-decoration-none">
                            Register as Psychiatrist
                        </a>
                    </p>
                </div>

                <!-- Forgot Password -->
                <div class="text-center">
                    <a href="{{ path('app_forgot_password') }}" class="text-muted small">
                        Forgot password?
                    </a>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <div class="auth-footer text-center mt-4 pt-3 border-top">
            <div class="d-flex justify-content-center gap-3 small">
                <a href="#" class="text-muted text-decoration-none">Terms of Service</a>
                <span class="text-muted">•</span>
                <a href="#" class="text-muted text-decoration-none">Privacy Policy</a>
                <span class="text-muted">•</span>
                <a href="#" class="text-muted text-decoration-none">Contact Support</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Password Toggle Stimulus Controller
    application.register('password-toggle', class extends Stimulus.Controller {
        static targets = ['icon'];
        
        toggle(event) {
            const input = this.element.querySelector('input[type="password"], input[type="text"]');
            const isPassword = input.type === 'password';
            
            input.type = isPassword ? 'text' : 'password';
            this.iconTarget.classList.toggle('bi-eye-slash');
            this.iconTarget.classList.toggle('bi-eye');
        }
    });
    
    // Login Form Controller (handles loading state)
    application.register('login-form', class extends Stimulus.Controller {
        static targets = ['submitBtn', 'spinner'];
        
        submit(event) {
            const form = this.element;
            if (!form.checkValidity()) {
                event.preventDefault();
                return;
            }
            
            // Show loading state
            this.submitBtnTarget.disabled = true;
            this.spinnerTarget.classList.remove('d-none');
            this.submitBtnTarget.querySelector('.normal-text').classList.add('d-none');
            
            // Form will submit normally (Symfony handles the rest)
        }
    });
</script>
{% endblock %}